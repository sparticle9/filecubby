{
  "name": "filecubby",
  "version": "1.0.0",
  "description": "Owner-operated serverless object storage using Cloudflare KV and Telegram chunks",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:pm2": "pm2 start pnpm --name filecubby-dev -- run dev",
    "dev:pm2:logs": "pm2 logs filecubby-dev",
    "dev:pm2:stop": "pm2 delete filecubby-dev",
    "deploy": "wrangler deploy --env=\"\"",
    "deploy:staging": "wrangler deploy --env staging",
    "build": "wrangler deploy --env=\"\" --dry-run",
    "build:staging": "wrangler deploy --env staging --dry-run",
    "typecheck": "tsc --noEmit",
    "cf:kv:create": "wrangler kv namespace create",
    "setup": "node scripts/setup.mjs",
    "setup:check": "node scripts/setup.mjs --check",
    "provision:cloudflare": "node scripts/provisionCloudflare.mjs",
    "provision:staging": "node scripts/provisionCloudflare.mjs --env-file .env.staging",
    "provision:staging:dry-run": "node scripts/provisionCloudflare.mjs --env-file .env.staging --dry-run",
    "secrets:bootstrap": "node scripts/bootstrapSecrets.mjs",
    "init-admin": "node scripts/initAdmin.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "exponential-backoff": "^3.1.3",
    "file-type": "^22.0.1",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.0"
  }
}
